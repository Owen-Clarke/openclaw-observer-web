{
  "name": "openclaw-observer",
  "version": "0.1.2",
  "private": true,
  "description": "Windows desktop observer for a remote OpenClaw gateway.",
  "author": "OpenClaw Observer",
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack:win": "electron-builder --win --x64",
    "pack:win:dir": "electron-builder --win --x64 --dir",
    "pack:dir": "electron-builder --dir"
  },
  "build": {
    "appId": "ai.openclaw.observer",
    "productName": "OpenClaw Observer",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}
